{
    "airbnb": {
        "command": "npx",
        "args": [
            "-y",
            "@openbnb/mcp-server-airbnb",
            "--ignore-robots-txt"
        ],
        "transport": "stdio"
    },
    "google-calendar": {
        "command": "npx",
        "args": [
            "@cocal/google-calendar-mcp"
        ],
        "env": {
            "GOOGLE_OAUTH_CREDENTIALS": "<YOUR_GOOGLE_OAUTH_CREDENTIALS_PATH>",
            "ENABLED_TOOLS": "list-events,create-event,get-current-time,update-event"
        },
        "transport": "stdio"
    },
    "google-sheets": {
        "command": "uvx",
        "args": [
            "mcp-google-sheets@latest"
        ],
        "env": {
            "CREDENTIALS_PATH": "<YOUR_GOOGLE_CREDENTIALS_PATH>",
            "TOKEN_PATH": "<YOUR_GOOGLE_TOKEN_PATH>"
        },
        "transport": "stdio"
    },
    "yahoo-finance": {
        "command": "uvx",
        "args": [
            "mcp-yahoo-finance"
        ],
        "transport": "stdio"
    },
    "gmail": {
        "command": "npx",
        "args": [
            "@gongrzhe/server-gmail-autoauth-mcp"
        ],
        "transport": "stdio"
    }
}
